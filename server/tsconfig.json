{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "moduleDetection": "force",

    "jsx": "react-jsx",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },

    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,

    "noEmit": true,
    "useDefineForClassFields": false
  },
  "include": ["src"]
}